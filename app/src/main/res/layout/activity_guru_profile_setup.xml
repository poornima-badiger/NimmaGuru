<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFDF0">

    <!-- ── HEADER ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F4B400"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="36dp"
        android:paddingBottom="28dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Avatar circle -->
        <LinearLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/circle_white"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍🏫"
                android:textSize="48sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Guru Profile"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ಗುರು ಪ್ರೊಫೈಲ್ ರಚಿಸಿ"
            android:textSize="15sp"
            android:textColor="#FFF8E1"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- ── FORM CARD ──────────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- CARD WRAPPER -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- FULL NAME -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full Name"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/edtName"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="e.g. Vishwanath Sir"
                        android:background="#F8F9FA"
                        android:padding="14dp"
                        android:inputType="textPersonName"
                        android:layout_marginBottom="20dp"/>

                    <!-- SUBJECT -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📘"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Subject You Teach"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/edtSubject"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="e.g. Math, Science, English"
                        android:background="#F8F9FA"
                        android:padding="14dp"
                        android:layout_marginBottom="20dp"/>

                    <!-- FREE HOURS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏰"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Free Hours / Availability"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/edtTime"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="e.g. Sunday 10AM - 1PM"
                        android:background="#F8F9FA"
                        android:padding="14dp"
                        android:layout_marginBottom="20dp"/>

                    <!-- VILLAGE / LOCATION -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Village / Location"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/edtLocation"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="e.g. Gadag, Hubli, Hulkoti"
                        android:background="#F8F9FA"
                        android:padding="14dp"
                        android:layout_marginBottom="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- INFO BOX -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF8E1"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Your profile will be visible to students in your village. Fill all fields carefully."
                    android:textSize="13sp"
                    android:textColor="#795548"/>
            </LinearLayout>

            <!-- SAVE BUTTON -->
            <Button
                android:id="@+id/btnSaveGuru"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="✅  Save Guru Profile"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#F4B400"
                android:layout_marginBottom="12dp"/>

            <!-- GO TO HOME BUTTON -->
            <Button
                android:id="@+id/btnGoHome"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Go to Home"
                android:textSize="15sp"
                android:textColor="#E65100"
                android:backgroundTint="#FFF3E0"
                android:layout_marginBottom="30dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
