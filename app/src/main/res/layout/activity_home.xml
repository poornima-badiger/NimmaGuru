<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D47A1"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nimma Guru"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Community Mentorship App"
                android:textSize="12sp"
                android:textColor="#BBDEFB"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btnNavNotifications"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="🔔"
            android:textSize="20sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnNavSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="⚙️"
            android:textSize="20sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- NAV ROW -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/btnNavSearch"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🔍 Search"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:background="#E3F2FD"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnNavCalendar"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📅 Calendar"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:background="#E3F2FD"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnNavAppreciation"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🌟 Wall of Fame"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:background="#E3F2FD"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnNavAI"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🤖 AI Assistant"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="#F4B400"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- SUBJECT FILTER ROW -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAFA"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="All"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="#0D47A1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chipMath"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Math"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:background="#E3F2FD"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chipScience"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Science"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:background="#E3F2FD"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chipEnglish"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="English"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:background="#E3F2FD"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chipComputer"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Computer"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:background="#E3F2FD"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- SEARCH BAR -->
    <EditText
        android:id="@+id/etSearchGuru"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Search Guru Name or Subject"
        android:background="#FFFFFF"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"/>

    <!-- LABEL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nearby Gurus"
        android:textStyle="bold"
        android:textSize="17sp"
        android:textColor="#0D47A1"
        android:layout_marginStart="16dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"/>

    <!-- GURU LIST -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/layoutGuruContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

</LinearLayout>
