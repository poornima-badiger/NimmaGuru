<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- TOP HEADER BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D47A1"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_subtitle"
                android:textSize="13sp"
                android:textColor="#BBDEFB"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnNavNotifications"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="🔔"
            android:textSize="18sp"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnNavSettings"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="⚙️"
            android:textSize="18sp"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- QUICK NAV BUTTONS ROW -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <Button
                android:id="@+id/btnNavSearch"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🔍 Search"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:backgroundTint="#E3F2FD"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnNavCalendar"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="📅 Calendar"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:backgroundTint="#E3F2FD"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnNavAppreciation"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🌟 Wall of Fame"
                android:textSize="13sp"
                android:textColor="#0D47A1"
                android:backgroundTint="#E3F2FD"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnNavAI"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🤖 AI Assistant"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#F4B400"
                android:layout_marginEnd="8dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- CHIP FILTERS -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            android:text="@string/chip_all"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E3F2FD"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipMath"
            android:text="@string/chip_math"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E3F2FD"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipScience"
            android:text="@string/chip_science"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E3F2FD"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipEnglish"
            android:text="@string/chip_english"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E3F2FD"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipComputer"
            android:text="@string/chip_computer"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="#E3F2FD"/>

    </com.google.android.material.chip.ChipGroup>

    <!-- SEARCH BAR -->
    <EditText
        android:id="@+id/etSearchGuru"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="@string/search_hint"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"/>

    <!-- SECTION LABEL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nearby_gurus"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#0D47A1"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"/>

    <!-- GURU CARDS SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/layoutGuruContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

</LinearLayout>
