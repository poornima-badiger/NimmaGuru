<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D47A1"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎓 Student Profile"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AVATAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:text="🎓"
                    android:textSize="52sp"
                    android:gravity="center"
                    android:background="#E3F2FD"/>
            </LinearLayout>

            <!-- PROFILE CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤 Full Name"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#0D47A1"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etStudentName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Your full name"
                        android:background="#F8F9FA"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏫 Class / Grade"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#0D47A1"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etStudentClass"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="e.g. 10th Standard"
                        android:background="#F8F9FA"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏛️ School Name"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#0D47A1"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etStudentSchool"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="e.g. Government High School"
                        android:background="#F8F9FA"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📚 Interests / Subjects"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#0D47A1"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etStudentInterests"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="e.g. Math, Science, Computer"
                        android:background="#F8F9FA"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SAVE BUTTON -->
            <Button
                android:id="@+id/btnSaveStudentProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="💾 Save Profile"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0D47A1"
                android:layout_marginBottom="30dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
