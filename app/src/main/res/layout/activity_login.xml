<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="30dp">

        <!-- TOP SPACE -->
        <Space
            android:layout_width="wrap_content"
            android:layout_height="40dp"/>

        <!-- LOGO IMAGE -->
        <ImageView
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="Nimma Guru Logo"/>

        <!-- APP NAME -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nimma-Guru"
            android:textColor="#0D2C91"
            android:textStyle="bold"
            android:textSize="38sp"
            android:layout_marginTop="16dp"/>

        <!-- TAGLINE ENGLISH -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Knowledge Sharing for Every Village"
            android:textColor="#555555"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

        <!-- TAGLINE KANNADA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ಪ್ರತಿ ಹಳ್ಳಿಗೂ ಜ್ಞಾನದ ಹಂಚಿಕೆ"
            android:textColor="#0D2C91"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="8dp"/>

        <!-- DIVIDER -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:background="#0D47A1"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp"/>

        <!-- WHO ARE YOU LABEL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Who are you?"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="20dp"/>

        <!-- STUDENT LOGIN BUTTON -->
        <Button
            android:id="@+id/btnStudent"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🎓  I am a Student"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#0D47A1"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- GURU LOGIN BUTTON -->
        <Button
            android:id="@+id/btnGuru"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="👨‍🏫  I am a Guru"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#F4B400"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <!-- REGISTER LINK -->
        <TextView
            android:id="@+id/txtRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New User? Register Here"
            android:textSize="15sp"
            android:textColor="#0D47A1"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <Space
            android:layout_width="wrap_content"
            android:layout_height="30dp"/>

    </LinearLayout>

</ScrollView>
