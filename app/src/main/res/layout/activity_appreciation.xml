<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0D47A1"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌟 Wall of Fame"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <!-- POST APPRECIATION CARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Say Thank You to Your Guru 🙏"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <EditText
                android:id="@+id/etGuruNameAppreciation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Guru Name"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:background="#F0F4FF"
                android:inputType="textPersonName"/>

            <EditText
                android:id="@+id/etThankYouMessage"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Write your thank you message..."
                android:layout_marginTop="10dp"
                android:padding="12dp"
                android:background="#F0F4FF"
                android:gravity="top"
                android:inputType="textMultiLine"/>

            <Button
                android:id="@+id/btnSubmitAppreciation"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Post Appreciation"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#0D47A1"
                android:layout_marginTop="12dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- WALL LABEL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Appreciation Wall"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"/>

    <!-- APPRECIATION LIST -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/layoutAppreciationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

</LinearLayout>
